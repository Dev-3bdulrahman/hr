{
    "name": "dev-3bdulrahman/hr",
    "description": "A Human Resources module for Laravel ERP — employees, attendance, leaves & payroll.",
    "type": "library",
    "version": "1.0.2",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulrahman",
            "homepage": "https://3bdulrahman.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dev3bdulrahman\\Hr\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dev3bdulrahman\\Hr\\Providers\\HrServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
